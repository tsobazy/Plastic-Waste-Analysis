```{r}
#| fig-alt: "Bubble plot showing internet user percentage by total plastic collected per country, additionally with country statistics when hovering over each circle."

# Visualization of internet user % by total plastic collected for each country
bubble_plot <- population_plastics |>
  filter(parent_company == "Grand Total",
         country != "Empty",
         !is.na(region)) |>
  ggplot(
    aes(x = internet_users, 
        y = grand_total, 
        size = volunteers, 
        color = region,
        text = paste("Country:", country,
                     "<br>Internet Users:", internet_users, "%",
                     "<br>Plastic Collected:", scales::comma(grand_total),
                     "<br>Volunteers:", scales::comma(volunteers),
                     "<br>Region:", region))
    ) +
  geom_point(alpha = 0.5) +
  scale_x_continuous(labels = scales::label_comma()) +
  scale_y_log10(labels = scales::label_comma()) +
  scale_size_continuous(
    labels = scales::label_comma(),
    range = c(5, 25)
    ) +
  scale_color_manual(
  values = unname(Polychrome::palette36.colors(18))
  )  +
  labs(
    x = "Internet Users (Percent of Population)",
    y = "",
    size = "Volunteers",
    color = "Region",
    title = "Internet Users vs. Total Plastic Collected (Log Scale) Per Country<br><sup>(Bubble Size = # of Volunteers)</sup>"
    ) +
  theme_minimal() +
  theme(
    legend.position = "none",
    plot.title = element_text(size = 14)
    )

ggplotly(bubble_plot, tooltip = "text")
```


```{r}
# Distribution of Total Plastic Collected by Urban Population Growth Rate

population_plastics |>
  summarize(
    min = min(urban_population_growth, na.rm = TRUE),
    max = max(urban_population_growth, na.rm = TRUE)
    )

pop <- population_plastics |>
  mutate(urban_growth = factor(
    ifelse(urban_population_growth > 4, "High Growth",
    ifelse(urban_population_growth > 3, "Medium Growth",
    ifelse(urban_population_growth > 2, "Med-Low Growth",
    ifelse(urban_population_growth > 1, "Low Growth",
    ifelse(urban_population_growth > 0, "No Growth",
                                        "Negative Growth"))))),
    levels = c("Negative Growth", "No Growth",
               "Low Growth" , "Med-Low Growth",
               "Medium Growth", "High Growth"),
    ordered = TRUE
  ))

pop |>
  filter(parent_company == "Grand Total", !is.na(region), threatened_species > 0) |>
  ggplot(
    aes(x = grand_total, y = factor(urban_growth), 
        fill = factor(urban_growth))
    ) +
  geom_density_ridges(scale = 0.8, alpha = 0.7) +
  scale_x_log10(labels = scales::label_comma()) +
  labs(title = "Distribution of Plastic Waste Collected by Urban Population Growth",
       x = "Total Plastic Collected (log scale)",
       y = "Population Growth") +
  theme_minimal() +
  theme(legend.position = "none")
```

```{r}
#Linear Model used to figure out total contribution of number of volunteers on plastic grand total. 

plastics_model <- plastics |>
  filter(!parent_company %in% c("NULL", "Unknown", "Grand Total")) |>
  mutate(parent_company = fct_lump_n(as.factor(parent_company), n = 10)) |>
  lm(grand_total ~ volunteers + year + parent_company, data = _)

anova(plastics_model) |>
  tidy() |>
  mutate(
    pct_variance = sumsq / sum(sumsq) * 100,
    term = recode(term,
                  volunteers     = "Volunteers",
                  year           = "Year",
                  parent_company = "Parent Company",
                  Residuals      = "Unexplained")
  ) |>
  select(term, df, sumsq, pct_variance, statistic, p.value) |>
  gt() |>
  tab_header(
    title = "How Much of Plastic Collected Is Explained by Volunteers?",
    subtitle = "Variance in grand_total partitioned across predictors"
  ) |>
  cols_label(
    term         = "Source",
    df           = "df",
    sumsq        = "Sum of Squares",
    pct_variance = "% of Variance",
    statistic    = "F",
    p.value      = "p-value"
  ) |>
  fmt_number(columns = c(sumsq, statistic), decimals = 1) |>
  fmt_number(columns = pct_variance, decimals = 1) |>
  fmt_number(columns = p.value, decimals = 4) |>
  sub_missing(missing_text = "—") |>
  tab_style(
    style = list(cell_fill(color = "#FFF3B0"), cell_text(weight = "bold")),
    locations = cells_body(rows = term == "Volunteers")
  ) |>
  tab_source_note(
    paste0("Model R² = ", round(summary(plastics_model)$r.squared, 3),
           " · n = ", nobs(plastics_model))
  )
```


